# ============================================
# 环境配置（非敏感）
# 复制 .env.example 为 .env 后修改
# ============================================

# Docker Compose 项目名称
COMPOSE_PROJECT_NAME=knowflow

# 运行环境
NODE_ENV=development

# 服务端口（主机:容器）
BACKEND_PORT=3002
FRONTEND_PORT=8002

# MongoDB 外部访问端口（留空=不暴露）
# MONGODB_EXTERNAL_PORT=27017

# ============================================
# 后端配置
# ============================================
API_VERSION=v1

# 数据目录
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# 插件目录
PLUGINS_DIR=./plugins

# MongoDB 配置（非敏感，敏感信息通过 Secrets 管理）
MONGODB_DB_NAME=knowflow

# AI 配置（豆包）
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_MODEL=ep-20260304151850-xqxr9

# CORS 配置
CORS_ORIGINS=*

# ============================================
# 前端配置
# ============================================
VITE_APP_TITLE=KnowFlow
VITE_APP_DESCRIPTION=知识管理系统
VITE_APP_VERSION=1.0.0

# 本地开发时使用 BACKEND_PORT (3002)
# Docker 部署时由 docker-compose.yml 覆盖为 knowflow-backend:3000
VITE_API_BASE_URL=http://localhost:${BACKEND_PORT}

# 仅前端模式：指定后端 API 地址
FRONTEND_API_BASE_URL=http://localhost:3000

# API 超时（毫秒）
VITE_API_TIMEOUT=30000

# 功能开关
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK=false
