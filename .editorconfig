# EditorConfig is awesome: https://EditorConfig.org
# 跨编辑器 / IDE 的代码格式配置文件

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,vue,json,css,scss,less,html,md,yml,yaml}]
indent_size = 2

[*.{py}]
indent_size = 4

[Makefile]
indent_style = tab
